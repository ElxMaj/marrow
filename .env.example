# Marrow configuration. copy to .env.local (gitignored) and fill in.
# reads and ingestion work with only DATABASE_URL. distillation also needs a
# model key (below). embeddings are zero-config by default (a local model runs
# in-process), so you only set an embedding endpoint if you want your own.

# --- database (required) ---
# Postgres 16+ with the pgvector extension. `pnpm db:up` starts one matching this.
# or point this at any existing Postgres where `create extension vector` has run.
DATABASE_URL=postgres://marrow:marrow@localhost:5432/marrow

# --- model provider (required for distillation) ---
# which provider distills the room. default: claude.
MARROW_PROVIDER=claude
# api key for the claude provider.
MARROW_API_KEY=sk-ant-...
# optional model override (default: claude-sonnet-4-6, a mid-tier model).
# MARROW_MODEL=claude-sonnet-4-6

# --- embeddings (zero-config by default) ---
# Anthropic has NO embeddings API. by default Marrow runs a small embedding model
# in-process (Xenova/all-MiniLM-L6-v2, ~25MB cached on first use) so distillation
# works with no endpoint and no key. you only set the variables below to use your
# OWN embedding endpoint instead. options:
#
# override the local model id (still in-process):
# MARROW_LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
#
# 1) local Ollama, no key:  `ollama pull nomic-embed-text`
# MARROW_EMBEDDING_BASE_URL=http://localhost:11434/v1
# MARROW_EMBEDDING_MODEL=nomic-embed-text
# MARROW_EMBEDDING_API_KEY=   # ollama needs none
#
# 2) any hosted OpenAI-compatible embedding endpoint (open models, etc.):
# MARROW_EMBEDDING_BASE_URL=https://your-endpoint/v1
# MARROW_EMBEDDING_API_KEY=...
# MARROW_EMBEDDING_MODEL=...

# --- fully local / self-hosted model (alternative to claude) ---
# point both model and (by default) embeddings at one OpenAI-compatible server.
# MARROW_PROVIDER=openai-compatible
# MARROW_BASE_URL=http://localhost:11434/v1
# MARROW_MODEL=llama3
# MARROW_API_KEY=            # often empty for local servers
# MARROW_EMBEDDING_MODEL=nomic-embed-text

# --- connectors (optional) ---
# Set any of these to enable scheduled ingestion from external tools.
# SLACK_BOT_TOKEN=xoxb-...
# NOTION_TOKEN=secret_...
# GITHUB_TOKEN=ghp_...
# FIGMA_TOKEN=figd_...
# INTERCOM_TOKEN=...
# ZOOM_ACCOUNT_ID=...
# ZOOM_CLIENT_ID=...
# ZOOM_CLIENT_SECRET=...
# LINEAR_TOKEN=lin_api_...
