{
  "name": "marrow",
  "version": "0.0.0",
  "private": true,
  "description": "The product context layer for coding agents",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --workspace-concurrency=1 test && node --test scripts/*.test.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter core db:migrate",
    "launch:preflight": "node scripts/launch-preflight.mjs",
    "smoke:packed": "node scripts/packed-smoke.mjs",
    "marrow": "tsx packages/cli/src/main.ts",
    "benchmark": "tsx packages/core/scripts/benchmark.ts",
    "demo": "tsx packages/core/scripts/demo.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.4.0"
  }
}
