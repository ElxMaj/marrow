{
  "name": "@marrowhq/web",
  "description": "Marrow web, the question-loop view. Browse the brain, see decided vs open facts with provenance back to the exact source span, and batch-answer what the room left open.",
  "version": "0.5.0",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "marrow",
    "product-context",
    "provenance",
    "question-loop",
    "coding-agents"
  ],
  "homepage": "https://github.com/ElxMaj/marrow#readme",
  "bugs": "https://github.com/ElxMaj/marrow/issues",
  "author": "Marrow",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElxMaj/marrow.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "vite",
    "start": "tsx src/server-main.ts"
  },
  "dependencies": {
    "@marrowhq/core": "workspace:*",
    "@marrowhq/shared": "workspace:*"
  },
  "devDependencies": {
    "@fontsource-variable/archivo": "5",
    "@fontsource-variable/geist": "5",
    "@fontsource-variable/geist-mono": "5",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "vite": "^5.4.0"
  }
}
