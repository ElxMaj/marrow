{
  "name": "@marrowhq/core",
  "description": "The Marrow engine: ingest the raw product room, distill it into decided vs open product truth with provenance, and serve task-scoped context to coding agents over MCP. One Postgres plus pgvector, provider interface, default Claude.",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "migrations",
    "scripts/migrate.mjs",
    "fixtures/synthetic-golden.json",
    "fixtures/write-golden.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@marrowhq/shared": "workspace:*",
    "js-tiktoken": "^1.0.12",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  },
  "license": "Apache-2.0",
  "keywords": [
    "marrow",
    "mcp",
    "coding-agents",
    "product-context",
    "provenance",
    "distillation",
    "postgres",
    "pgvector",
    "claude"
  ],
  "homepage": "https://github.com/ElxMaj/marrow#readme",
  "bugs": "https://github.com/ElxMaj/marrow/issues",
  "author": "Marrow",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElxMaj/marrow.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
